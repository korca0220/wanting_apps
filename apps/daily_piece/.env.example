# Copy this file to `.env` and fill in real values for local development.
# `.env` is gitignored. CI uses GitHub Secrets to write its own .env.
#
# After editing .env, regenerate the typed Env class:
#   melos run gen
# (or directly: dart run build_runner build --delete-conflicting-outputs)

SUPABASE_URL=
SUPABASE_ANON_KEY=
